config ADC_ADE7913
	bool "Analog Devices ADE7913 SPI ADC"
	select SPI
	default y
	depends on DT_HAS_TI_ADE7913_ENABLED

if ADC_ADE7913

config ADC_ADE7913_INIT_PRIORITY
	int "ADE7913 init priority"
	default SPI_INIT_PRIORITY
	help
	  ADE7913 device initialization.

config ADC_ADE7913_ACQUISITION_THREAD_STACK_SIZE
	int "Stack size for the ADC data acquisition thread"
	default 512
	help
	  Size of the stack used for the internal data acquisition
	  thread.

config ADC_ADE7913_ACQUISITION_THREAD_PRIORITY
	int "Priority for the ADC data acquisition thread"
	default 0
	help
	  Priority level for the internal ADC data acquisition thread.

endif # ADC_ADE7913
